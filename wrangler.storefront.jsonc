{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ngbr-example-storefront",
  "compatibility_date": "2026-06-14",
  "assets": {
    "directory": "dist/storefront/browser",
    "not_found_handling": "single-page-application",
  },
  "routes": [{ "pattern": "storefront.ngbracket.com", "custom_domain": true }],
}
