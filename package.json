{
  "name": "ngbracket-examples",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve admin",
    "start:admin": "ng serve admin",
    "start:storefront": "ng serve storefront",
    "start:booking": "ng serve booking",
    "build": "ng build admin && ng build storefront && ng build booking",
    "build:admin": "ng build admin",
    "build:storefront": "ng build storefront",
    "build:booking": "ng build booking",
    "deploy:admin": "ng build admin && wrangler deploy -c wrangler.admin.jsonc",
    "deploy:storefront": "ng build storefront && wrangler deploy -c wrangler.storefront.jsonc",
    "deploy:booking": "ng build booking && wrangler deploy -c wrangler.booking.jsonc",
    "deploy": "npm run deploy:admin && npm run deploy:storefront && npm run deploy:booking",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/aria": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ngbracket/auth": "0.1.2",
    "@ngbracket/commerce": "0.1.0",
    "@ngbracket/dashboard": "0.1.0",
    "@ngbracket/data-table": "0.2.0",
    "@ngbracket/forms": "0.2.0",
    "@ngbracket/marketing": "0.1.0",
    "@ngbracket/scheduler": "0.5.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8",
    "wrangler": "^4.0.0"
  }
}
