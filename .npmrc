; NgBracket private packs are served from the registry proxy.
; The token is read from the NGBRACKET_TOKEN environment variable at install time —
; it is NEVER committed. Run `export NGBRACKET_TOKEN=ngbr_…` before `npm install`.
@ngbracket:registry=https://registry.ngbracket.com
//registry.ngbracket.com/:_authToken=${NGBRACKET_TOKEN}
